// -*- mode: json -*-
{
	"layer": "bottom",
	"position": "top",
	"modules-left": [
		"sway/workspaces",
		// "wlr/taskbar",
		"sway/mode",
		"custom/spotify",
		"idle_inhibitor"
	],
	"modules-center": [
		"clock",
		"custom/weather"
	],
	"modules-right": [
	    "custom/keyboard",
		"cpu",
		"memory",
		"custom/swap",
		"disk#1",
		"disk#2",
		"pulseaudio",
		"backlight",
		"battery",
		"tray"
	],
	"sway/workspaces": {
		"disable-scroll": true,
 		"all-outputs": true,
 		"format": "{name} {icon}",
		"format-icons": {
			"1- Web": "´ëę",
			"2- Terminals": "´äá",
